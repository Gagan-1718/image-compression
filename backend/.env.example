# Environment Configuration

# App Settings
DEBUG=False
APP_NAME="Interactive Image Compression Lab"
APP_VERSION="1.0.0"

# Server Settings
HOST=0.0.0.0
PORT=8000

# File Upload Settings (in bytes)
MAX_UPLOAD_SIZE=536870912  # 500 MB

# Storage Paths
UPLOAD_DIR=./storage/uploads
COMPRESSED_DIR=./storage/compressed

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/compression_lab
